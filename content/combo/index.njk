---
layout: layouts/base.njk
reverse: false
page-description: Home page of the HKBC.
---
<h1 class="toph">Selected Reading List</h1>
{% set posts = collections.all | withTwoTags("reading", "hkbc") | reverse %}
{% for post in posts %}
  <a href="{{ post.url }}">{{ post.data.title }}</a>
  {% if post.data.writer %}
  ({% set writerList = post
      .data
      .writer
      .split(',') %}
    {% for writerName in writerList %}
      <a href="/writers/{{ writerName.trim() | slugify }}/">{{ writerName.trim() }}</a>
      {% if not loop.last %}, {% endif %}
    {% endfor %})
{% endif %} &nbsp;&nbsp; <span class="post-date">
    <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
  </span>
  <br>{% endfor %}