{
  "name": "simple",
  "version": "0.1",
  "description": "Text-only Eleventy site derived from midlevels/startmeup.",
  "type": "module",
  "scripts": {
    "build:all": "npx @11ty/eleventy && npm run build:index",
    "build:index": "npx -y pagefind --site _site",
    "og:image": "node scripts/generate-og-images.js",
    "og:image:force": "node scripts/generate-og-images.js --force",
    "start": "npx @11ty/eleventy --serve --quiet",
    "debug": "cross-env DEBUG=Eleventy* npx @11ty/eleventy",
    "debugstart": "cross-env DEBUG=Eleventy* npx @11ty/eleventy --serve --quiet",
    "benchmark": "cross-env DEBUG=Eleventy:Benchmark* npx @11ty/eleventy",
    "setup-cms": "npm --prefix cms install",
    "cms": "npm --prefix cms start"
  },
  "author": {
    "name": "Dave Ross",
    "email": "davidrosshk@gmail.com",
    "url": "https://daveross.name/"
  },
  "license": "MIT",
  "engines": {
    "node": ">=23"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/11ty"
  },
  "bugs": {
    "url": "https://github.com/11ty/eleventy-base-blog/issues"
  },
  "homepage": "https://github.com/11ty/eleventy-base-blog#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-img": "github:11ty/eleventy-img",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@zachleat/pagefind-search": "^1.0.3",
    "cross-env": "^7.0.3",
    "luxon": "^3.6.1",
    "prismjs": "^1.30.0",
    "zod": "^3.25.67",
    "zod-validation-error": "^3.5.2"
  },
  "dependencies": {
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "@zachleat/heading-anchors": "^1.0.5",
    "clean-css": "^5.3.3",
    "gray-matter": "^4.0.3",
    "jsdom": "^27.0.1",
    "markdown-it": "^14.1.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-link-attributes": "^4.0.1",
    "node-html-parser": "^7.0.1",
    "prism-themes": "^1.9.0",
    "sharp": "^0.34.5",
    "widont": "^0.4.0"
  }
}
